# Base URL of the PHP API backend (no trailing slash).
#
# Leave UNSET to use the relative "/api" path (only works if the api/ folder is
# served from the same domain as the site).
#
# For the standalone API on a subdomain, set this and rebuild:
#   Local dev  ->  copy to .env.local with:  VITE_API_BASE=http://localhost:8000
#   Production ->  copy to .env.production with your real subdomain below.
VITE_API_BASE=https://api.fourwheelszone.com
